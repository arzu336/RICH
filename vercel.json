{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix web-frontend",
  "buildCommand": "npm run build --prefix web-frontend",
  "outputDirectory": "web-frontend/dist",
  "functions": {
    "web-frontend/api/**/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/web-frontend/api/$1" }
  ],
  "framework": null
}
