{
  "info": {
    "_postman_id": "rich-arzu-kucuk-collection",
    "name": "Arzu KUCUK - RICH",
    "description": "Arzu Kucuk REST API gereksinimleri - 8 endpoint (RichBackend ile uyumlu)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5227"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "1 - Kullanici Kayit",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Arzu Kucuk\",\n  \"email\": \"arzu.test@example.com\",\n  \"password\": \"Guvenli123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "2 - Kullanici Giris",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json();",
              "if (data.userId) {",
              "  pm.collectionVariables.set('userId', String(data.userId));",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"arzu.test@example.com\",\n  \"password\": \"Guvenli123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "3 - Kullanici Cikis",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "logout"]
        }
      },
      "response": []
    },
    {
      "name": "4 - Kullanici Hesap Sil",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/auth/delete/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "delete", "{{userId}}"]
        }
      },
      "response": []
    },
    {
      "name": "5 - Kadin Urunleri Listele",
