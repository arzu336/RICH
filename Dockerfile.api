FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY RichBackend/RichBackend.csproj RichBackend/
RUN dotnet restore RichBackend/RichBackend.csproj

COPY RichBackend/ RichBackend/
RUN dotnet publish RichBackend/RichBackend.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app

COPY --from=build /app/publish .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "RichBackend.dll"]
